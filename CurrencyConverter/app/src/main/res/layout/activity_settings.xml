<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_settings.xml
    ─────────────────────────────────────────────────────────────
    Layout for the Settings screen.

    Widgets used (from syllabus):
      • ConstraintLayout  – primary layout
      • TextView          – labels
      • SwitchCompat      – toggle Dark / Light theme
      • Button            – navigate back to MainActivity
    ─────────────────────────────────────────────────────────────
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- ── Settings Title ───────────────────────────────── -->
    <TextView
        android:id="@+id/tv_settings_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_settings"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ── Divider line under title ─────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.2"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_settings_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Dark Mode Label ──────────────────────────────── -->
    <TextView
        android:id="@+id/tv_dark_mode_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/label_dark_mode"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switch_theme"
        app:layout_constraintBottom_toBottomOf="@id/switch_theme" />

    <!--
        ── Dark Mode Switch (SwitchCompat from AppCompat) ──
        SwitchCompat is the back-compat version of Switch,
        used as taught in the Android UI Design lecture.
    -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_theme"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Back Button ───────────────────────────────────── -->
    <Button
        android:id="@+id/btn_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>