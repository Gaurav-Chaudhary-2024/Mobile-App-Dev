<?xml version="1.0" encoding="utf-8"?>
<!--
    Gallery screen layout:
    - Choose Folder button at top
    - Empty state message when no folder selected
    - RecyclerView grid fills remaining space
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!--
        Top card: Choose Folder button
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_folder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!--
                Choose Folder button
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_choose_gallery_folder"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_choose_gallery_folder"
                app:icon="@drawable/ic_gallery"
                app:cornerRadius="12dp" />

            <!--
                Selected folder name — shown after folder is picked
            -->
            <TextView
                android:id="@+id/txt_selected_folder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/gallery_placeholder"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!--
        Empty state — shown when folder has no images
        or no folder selected yet
    -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@+id/card_folder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_gallery"
            android:contentDescription="Empty gallery"
            android:alpha="0.4"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/txt_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/gallery_placeholder"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:padding="16dp" />

    </LinearLayout>

    <!--
        RecyclerView — shows image grid
        Initially GONE, shown after folder is selected
        GridLayoutManager with 3 columns set in Java
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_gallery"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/card_folder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>