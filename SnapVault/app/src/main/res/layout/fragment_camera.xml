<?xml version="1.0" encoding="utf-8"?>
<!--
    Camera screen layout:
    PreviewView fills the top (live camera viewfinder)
    Controls card sits at the bottom
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!--
        CameraX PreviewView — shows live camera feed
        This is the viewfinder the user sees before capturing
    -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/card_camera_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Camera Controls Card
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_camera_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!--
                Save folder indicator
                Shows where photos will be saved
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/save_folder_label"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:id="@+id/txt_save_folder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/default_folder"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:ellipsize="start"
                    android:singleLine="true"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!--
                Buttons row: Choose Folder | Capture
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Choose folder button — outlined style -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_choose_folder"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/btn_choose_folder"
                    app:icon="@drawable/ic_gallery"
                    app:cornerRadius="12dp" />

                <!-- Capture button — filled, prominent -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_capture"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/btn_capture"
                    app:icon="@drawable/ic_camera"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>